# ========== App ==========
APP_NAME=fastapi_reviews
ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api

# 前端开发时的跨域白名单，多个值用逗号分隔
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:5173

# ========== Database ==========
# 本地开发可用 localhost，Docker Compose 场景请改成 db
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/review_backend

# ========== Redis ==========
# 本地开发可用 localhost，Docker Compose 场景请改成 redis
REDIS_URL=redis://localhost:6379/0

# ========== AI Recommendation ==========
# 使用阿里云百炼 DashScope 兼容模式调用 Qwen embedding
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v4
AI_RECOMMENDATION_CANDIDATE_LIMIT=60
AI_RECOMMENDATION_PROFILE_HISTORY_LIMIT=12
AI_RECOMMENDATION_PROFILE_FAVORITE_LIMIT=12
AI_RECOMMENDATION_EMBEDDING_DIMENSIONS=1024
AI_RECOMMENDATION_REQUEST_TIMEOUT=30

# 说明：
# 1. 当前项目配置默认从 `.venv/.env` 读取环境变量。
# 2. 你可以把本文件复制为 `.venv/.env` 后再按需修改。
